# ══════════════════════════════════════════════════════════
# AI PROVIDER — Google Gemini
# ══════════════════════════════════════════════════════════
AI_PROVIDER=gemini
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-2.5-flash
AI_MAX_TOKENS=1600
AGENT_MAX_TOOL_ROUNDS=8

# ══════════════════════════════════════════════════════════
# AGENT HTTP SERVER
# ══════════════════════════════════════════════════════════
NODE_ENV=production
PORT=3000
LOG_LEVEL=info
MCP_READONLY=true

# ══════════════════════════════════════════════════════════
# MCP STDIO CHILD PROCESS COMMANDS
# ══════════════════════════════════════════════════════════
ZEEK_MCP_COMMAND=node
ZEEK_MCP_ARGS=../zeek-mcp/dist/index.js
SURICATA_MCP_COMMAND=node
SURICATA_MCP_ARGS=../suricata-mcp/dist/index.js
MITRE_MCP_COMMAND=node
MITRE_MCP_ARGS=../mitre-mcp/dist/index.js

# ══════════════════════════════════════════════════════════
# SENSOR LOG PATHS (NFS-mounted from sensor VM)
# ══════════════════════════════════════════════════════════
# NOTE: Mount /opt/zeek/spool/zeek (NOT /opt/zeek/logs/current)
# because 'current' is a symlink that breaks over NFS
ZEEK_LOG_DIR=/mnt/zeek-logs
ZEEK_LOG_PATH=/mnt/zeek-logs
ZEEK_LOGS_DIR=/mnt/zeek-logs
ZEEK_LOG_FORMAT=tsv

SURICATA_EVE_LOG=/mnt/suricata-logs/eve.json
EVE_JSON_PATH=/mnt/suricata-logs/eve.json

# ══════════════════════════════════════════════════════════
# MITRE ATT&CK
# ══════════════════════════════════════════════════════════
MITRE_MATRICES=enterprise
