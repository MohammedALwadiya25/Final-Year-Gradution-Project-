NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Free Google AI Studio/Gemini setup
AI_PROVIDER=gemini
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-1.5-flash
AI_MAX_TOKENS=1600
AGENT_MAX_TOOL_ROUNDS=5

# Optional: API key for /investigate endpoint protection
# Leave empty or set to "none" to disable auth
AGENT_API_KEY=none

# Thesis/demo default: the agent can investigate but cannot write/block directly.
MCP_READONLY=true

# Local stdio MCP server commands. Build each MCP repo first.
ZEEK_MCP_COMMAND=node
ZEEK_MCP_ARGS=../zeek-mcp/dist/index.js
SURICATA_MCP_COMMAND=node
SURICATA_MCP_ARGS=../suricata-mcp/dist/index.js
WAZUH_MCP_COMMAND=node
WAZUH_MCP_ARGS=../wazuh-mcp/dist/index.js
MITRE_MCP_COMMAND=node
MITRE_MCP_ARGS=../mitre-mcp/dist/index.js

# Sensor paths. These aliases match both the guide and the current MCP code.
ZEEK_LOG_DIR=../zeek-mcp/test-logs
ZEEK_LOG_FORMAT=tsv
SURICATA_EVE_LOG=../suricata-mcp/test-logs/eve.json
ZEEK_LOGS_DIR=../zeek-mcp/test-logs

# Wazuh API and optional indexer. Do not commit real passwords.
# Leave empty if Wazuh is not available - agent will use fallback mode
WAZUH_URL=
WAZUH_USERNAME=
WAZUH_PASSWORD=
WAZUH_VERIFY_SSL=false
WAZUH_INDEXER_URL=
WAZUH_INDEXER_USERNAME=
WAZUH_INDEXER_PASSWORD=
WAZUH_INDEXER_VERIFY_SSL=false

MITRE_MATRICES=enterprise